init__()\n        self.norm1 = nn.LayerNorm(dim)\n        self.attn  = nn.MultiheadAttention(dim, num_heads, dropout=dropout, batch_first=True)\n        self.norm2 = nn.LayerNorm(dim)\n        self.mlp   = nn.Sequential(\n            nn.Linear(dim, int(dim * mlp_ratio)),\n            nn.GELU(),\n            nn.Dropout(dropout),\n            nn.Linear(int(dim * mlp_ratio), dim),\n            nn.Dropout(dropout)\n        )\n\n    def forward(self, x):\n        normed = self.norm1(x)\n        x = x + self.attn(normed, normed, normed, need_weights=False)[0]\n        x = x + self.mlp(self.norm2(x))\n        return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:33.724096Z","iopub.execute_input":"2026-03-11T01:48:33.724450Z","iopub.status.idle":"2026-03-11T01:48:33.731707Z","shell.execute_reply.started":"2026-03-11T01:48:33.724419Z","shell.execute_reply":"2026-03-11T01:48:33.731026Z"}},"outputs":[],"execution_count":9},{"cell_type":"code","source":"class MAEEncoder(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.patch_embed = PatchEmbed()\n        self.blocks      = nn.Sequential(*[TransformerBlock(ENC_DIM, ENC_HEADS) for _ in range(ENC_LAYERS)])\n        self.norm        = nn.LayerNorm(ENC_DIM)\n\n        pos = get_2d_sincos_pos_embed(ENC_DIM, IMG_SIZE // PATCH_SIZE)\n        self.register_buffer('pos_embed', pos.unsqueeze(0))\n\n    def forward(self, x):\n        x = self.patch_embed(x)\n        x = x + self.pos_embed\n\n        x, mask, ids_restore = random_masking(x)\n\n        x = self.blocks(x)\n        x = self.norm(x)\n\n        return x, mask, ids_restore","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:33.732680Z","iopub.execute_input":"2026-03-11T01:48:33.732905Z","iopub.status.idle":"2026-03-11T01:48:33.747519Z","shell.execute_reply.started":"2026-03-11T01:48:33.732887Z","shell.execute_reply":"2026-03-11T01:48:33.746823Z"}},"outputs":[],"execution_count":10},{"cell_type":"markdown","source":"## 5) Decoder (ViT-Small)","metadata":{}},{"cell_type":"code","source":"class MAEDecoder(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.proj        = nn.Linear(ENC_DIM, DEC_DIM)\n        self.mask_token  = nn.Parameter(torch.zeros(1, 1, DEC_DIM))\n        self.blocks      = nn.Sequential(*[TransformerBlock(DEC_DIM, DEC_HEADS) for _ in range(DEC_LAYERS)])\n        self.norm        = nn.LayerNorm(DEC_DIM)\n        self.pred        = nn.Linear(DEC_DIM, PATCH_SIZE * PATCH_SIZE * 3)\n\n        pos = get_2d_sincos_pos_embed(DEC_DIM, IMG_SIZE // PATCH_SIZE)\n        self.register_buffer('pos_embed', pos.unsqueeze(0))\n\n        nn.init.normal_(self.mask_token, std=0.02)\n\n    def forward(self, x, ids_restore):\n        B, N, D  = x.shape\n        x        = self.proj(x)\n\n        mask_tokens = self.mask_token.expand(B, ids_restore.shape[1] - N, -1)\n        x_full      = torch.cat([x, mask_tokens], dim=1)\n        x_full      = torch.gather(x_full, 1, ids_restore.unsqueeze(-1).expand(-1, -1, DEC_DIM))\n\n        x_full   = x_full + self.pos_embed\n        x_full   = self.blocks(x_full)\n        x_full   = self.norm(x_full)\n        x_full   = self.pred(x_full)\n\n        return x_full","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:33.748430Z","iopub.execute_input":"2026-03-11T01:48:33.748677Z","iopub.status.idle":"2026-03-11T01:48:33.766444Z","shell.execute_reply.started":"2026-03-11T01:48:33.748657Z","shell.execute_reply":"2026-03-11T01:48:33.765937Z"}},"outputs":[],"execution_count":11},{"cell_type":"markdown","source":"## 6) Full MAE Model + Forward Pass + Loss","metadata":{}},{"cell_type":"code","source":"def patchify(imgs):\n    B, C, H, W = imgs.shape\n    p  = PATCH_SIZE\n    h  = H // p\n    x  = imgs.reshape(B, C, h, p, h, p)\n    x  = x.permute(0, 2, 4, 1, 3, 5)\n    x  = x.reshape(B, h * h, p * p * C)\n    return x\n\ndef unpatchify(patches):\n    B, N, _ = patches.shape\n    p = PATCH_SIZE\n    h = int(N ** 0.5)\n    x = patches.reshape(B, h, h, p, p, 3)\n    x = x.permute(0, 5, 1, 3, 2, 4)\n    x = x.reshape(B, 3, h * p, h * p)\n    return x","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:33.768537Z","iopub.execute_input":"2026-03-11T01:48:33.768820Z","iopub.status.idle":"2026-03-11T01:48:33.781063Z","shell.execute_reply.started":"2026-03-11T01:48:33.768800Z","shell.execute_reply":"2026-03-11T01:48:33.780556Z"}},"outputs":[],"execution_count":12},{"cell_type":"code","source":"class MAE(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.encoder = MAEEncoder()\n        self.decoder = MAEDecoder()\n\n    def forward(self, x):\n        enc_out, mask, ids_restore = self.encoder(x)\n        dec_out                    = self.decoder(enc_out, ids_restore)\n\n        target = patchify(x)\n        loss   = F.mse_loss(dec_out[mask == 1], target[mask == 1])\n\n        return loss, dec_out, mask","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:33.781877Z","iopub.execute_input":"2026-03-11T01:48:33.782116Z","iopub.status.idle":"2026-03-11T01:48:33.800881Z","shell.execute_reply.started":"2026-03-11T01:48:33.782093Z","shell.execute_reply":"2026-03-11T01:48:33.800390Z"}},"outputs":[],"execution_count":13},{"cell_type":"markdown","source":"## 7) Training Loop","metadata":{}},{"cell_type":"code","source":"device   = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nnum_gpus = torch.cuda.device_count()\n\nmodel    = MAE().to(device)\n\nif num_gpus > 1:\n    model = nn.DataParallel(model)\n\nprint(f\"Training on : {num_gpus} GPU(s)\")\nprint(f\"Device      : {device}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:33.801589Z","iopub.execute_input":"2026-03-11T01:48:33.801853Z","iopub.status.idle":"2026-03-11T01:48:34.760132Z","shell.execute_reply.started":"2026-03-11T01:48:33.801827Z","shell.execute_reply":"2026-03-11T0