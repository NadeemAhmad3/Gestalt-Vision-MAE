.status.idle":"2026-03-11T01:48:28.915463Z","shell.execute_reply.started":"2026-03-11T01:48:28.900325Z","shell.execute_reply":"2026-03-11T01:48:28.914950Z"}},"outputs":[],"execution_count":5},{"cell_type":"code","source":"def get_2d_sincos_pos_embed(embed_dim, grid_size):\n    grid_h = np.arange(grid_size, dtype=np.float32)\n    grid_w = np.arange(grid_size, dtype=np.float32)\n    grid   = np.meshgrid(grid_w, grid_h)\n    grid   = np.stack(grid, axis=0).reshape(2, -1)\n\n    half   = embed_dim // 2\n    omega  = np.arange(half // 2, dtype=np.float32)\n    omega  = 1.0 / (10000 ** (2 * omega / half))\n\n    out_h  = np.einsum('n,d->nd', grid[0], omega)\n    out_w  = np.einsum('n,d->nd', grid[1], omega)\n\n    emb_h  = np.concatenate([np.sin(out_h), np.cos(out_h)], axis=1)\n    emb_w  = np.concatenate([np.sin(out_w), np.cos(out_w)], axis=1)\n\n    return torch.tensor(np.concatenate([emb_h, emb_w], axis=1), dtype=torch.float32)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:28.917038Z","iopub.execute_input":"2026-03-11T01:48:28.917646Z","iopub.status.idle":"2026-03-11T01:48:28.930607Z","shell.execute_reply.started":"2026-03-11T01:48:28.917609Z","shell.execute_reply":"2026-03-11T01:48:28.930112Z"}},"outputs":[],"execution_count":6},{"cell_type":"code","source":"def random_masking(x, mask_ratio=MASK_RATIO):\n    B, N, D   = x.shape\n    keep      = int(N * (1 - mask_ratio))\n\n    noise     = torch.rand(B, N, device=x.device)\n    ids_shuffle  = torch.argsort(noise, dim=1)\n    ids_restore  = torch.argsort(ids_shuffle, dim=1)\n\n    ids_keep     = ids_shuffle[:, :keep]\n    x_visible    = torch.gather(x, 1, ids_keep.unsqueeze(-1).expand(-1, -1, D))\n\n    mask         = torch.ones(B, N, device=x.device)\n    mask[:, :keep] = 0\n    mask         = torch.gather(mask, 1, ids_restore)\n\n    return x_visible, mask, ids_restore","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T01:48:28.931406Z","iopub.execute_input":"2026